{
  "name": "tiao-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter '@nightmarket/tiao' build",
    "dev": "pnpm --filter playground dev",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "publish:packages": "pnpm test && pnpm typecheck && pnpm --filter '@nightmarket/tiao' publish --access public"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.28.1"
}
