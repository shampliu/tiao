{
  "name": "@tiao/core",
  "version": "0.1.0",
  "description": "A themeable, draggable debug pane for tweaking parameters. Vanilla TS, zero dependencies.",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/tiao.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/tiao.css",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
